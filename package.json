{
  "name": "unmute-video",
  "displayName": "Video Player (with Audio) — MP4/MOV",
  "description": "Play MP4 / MOV / M4V videos inside VS Code with sound. Audio is extracted via ffmpeg and synced to the muted video, working around the missing AAC codec in the VS Code webview.",
  "version": "0.1.0",
  "publisher": "yutabee",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/yutabee/vscode-unmute-video.git"
  },
  "bugs": {
    "url": "https://github.com/yutabee/vscode-unmute-video/issues"
  },
  "galleryBanner": {
    "color": "#241b3a",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "video",
    "video player",
    "mp4",
    "audio",
    "preview"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "unmuteVideo.open",
        "title": "Open with Video Player (with Audio)"
      }
    ],
    "customEditors": [
      {
        "viewType": "unmuteVideo.viewer",
        "displayName": "Video Player (with Audio)",
        "priority": "default",
        "selector": [
          { "filenamePattern": "**/*.mp4" },
          { "filenamePattern": "**/*.mov" },
          { "filenamePattern": "**/*.m4v" }
        ]
      }
    ]
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true})\"",
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "pretest": "npm run compile",
    "test": "node --test \"test/**/*.test.js\"",
    "vscode:prepublish": "npm run clean && npm run compile",
    "package": "npx --yes @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0"
  }
}
